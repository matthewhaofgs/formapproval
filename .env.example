# Copy this file to .env or to your service manager's environment file.
# Do not commit real values.

NODE_ENV=production
PORT=3000
APP_BASE_URL=https://forms.example.edu

# PostgreSQL
DATABASE_URL=postgresql://formapproval:change-me@localhost:5432/formapproval
DEFINITION_CACHE_TTL_MS=5000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
OAUTH_REDIRECT_URI=https://forms.example.edu/auth/callback
OAUTH_ALLOWED_DOMAIN=example.edu
OAUTH_SESSION_MAX_AGE_SECONDS=28800
SESSION_SECRET=replace-with-a-long-random-secret

# SMTP
SMTP_HOST=smtp.example.edu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=forms@example.edu
SMTP_PASS=replace-with-smtp-app-password
MAIL_FROM_NAME=Workflow Approvals
MAIL_FROM_ADDRESS=forms@example.edu

# Scheduled jobs
SCHEDULED_JOB_ACTOR_EMAIL=system@example.edu

# Optional live regression tests. Keep unset for normal local test runs.
LIVE_FORM_TESTS=0
LIVE_FORM_SUBMIT=0
LIVE_FORM_URL=https://forms.example.edu
LIVE_FORM_SESSION_COOKIE=
REGRESSION_TEST_SECRET=replace-with-test-only-secret
