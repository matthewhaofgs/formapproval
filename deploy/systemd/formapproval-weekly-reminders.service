[Unit]
Description=OFG Forms weekly pending-reminder job
Wants=formapproval.service
After=formapproval.service postgresql.service

[Service]
Type=oneshot
User=ofgadmin
WorkingDirectory=/home/ofgadmin/codex-projects/formapproval
ExecStart=/usr/bin/node /home/ofgadmin/codex-projects/formapproval/scripts/run-scheduled-job.js sendWeeklyPendingReminders
